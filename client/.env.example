# رابط الـ backend على Render (بدون / في الآخر)
# ⚠️ مش بالضرورة https://<name>.onrender.com: لو الاسم اللي في render.yaml
# محجوز، Render بيضيف لاحقة عشوائية (عشان كده -9u88 هنا مع إن الاسم loopin-api).
# الرابط الحقيقي بيتقال في لوج الـ deploy عند "Available at your primary URL" —
# خده من هناك، متبنيهوش من الاسم.
# لو اتغير، لازم يتغير هنا **وفي متغيرات البيئة في لوحة Vercel كمان** — الملف ده
# مرجع بس، اللي بيتبني فعلاً هو اللي في اللوحة.
# في التطوير المحلي سيبه فاضي أو امسح السطر خالص — الـ Vite proxy هيتولى الأمر
VITE_API_URL="https://loopin-api-9u88.onrender.com"

# Cloudinary (رفع الصور) — من cloudinary.com (مجاني)
# اعمل unsigned upload preset من Settings → Upload
VITE_CLOUDINARY_CLOUD_NAME=""
VITE_CLOUDINARY_UPLOAD_PRESET=""
